# ══════════════════════════════════════════════════════════════════
# 기프트클린 네이버 블로그 작성 도우미 — 환경설정 예시
# 이 파일을 .env로 복사한 뒤 값을 채우세요: cp .env.example .env
# .env는 절대 git에 커밋하지 마세요 (.gitignore에 이미 포함되어 있음)
# ══════════════════════════════════════════════════════════════════

# ── 안전장치 (기본값을 함부로 바꾸지 마세요) ──────────────────────
# DRY_RUN=true 이면 네이버에 실제로 아무 것도 입력/저장하지 않고
# 생성된 글·사진 배치·태그·예정 동작만 화면에 보여줍니다.
# 처음 설치했다면 반드시 true로 먼저 테스트하세요.
DRY_RUN=true

# ── 네이버 계정 (⚠ 평문 저장 위험) ────────────────────────────────
# 아래 NAVER_ID/NAVER_PW는 .env 파일에 '평문(암호화되지 않은 문자)'으로 저장됩니다.
# 이 파일이 유출되면 네이버 계정이 그대로 노출됩니다. 아래 USE_CHROME_PROFILE을
# 우선 사용하는 것을 권장하며, 부득이하게 비밀번호를 쓴다면:
#   - 이 PC를 다른 사람과 공유하지 마세요
#   - .env 파일 권한을 본인만 읽을 수 있도록 제한하세요 (Windows: 파일 속성 → 보안)
#   - 사용 후 비밀번호를 주기적으로 변경하세요
NAVER_ID=
NAVER_PW=
BLOG_ID=

# USE_CHROME_PROFILE=true 이면 위 비밀번호 대신, 이 도구 전용 Chrome 프로필에
# 저장된 기존 로그인 세션을 재사용합니다(첫 실행 시 1회만 수동 로그인 필요).
# 비밀번호를 아예 저장하지 않아도 되는 더 안전한 방식입니다.
USE_CHROME_PROFILE=false
# CHROME_PROFILE_PATH=   # 비워두면 프로젝트 내 .chrome_profile/ 사용

# ── LLM API 키 (글 생성 — 하나 이상 필수) ─────────────────────────
CLAUDE_API_KEY=
OPENAI_API_KEY=

# ── 네이버 검색광고 API (키워드 검색량/경쟁도 조회, 없으면 수동입력 모드) ──
NAVER_SEARCHAD_API_KEY=
NAVER_SEARCHAD_SECRET_KEY=
NAVER_SEARCHAD_CUSTOMER_ID=

# ── 네이버 검색 API (블로그 문서수=경쟁도 조회) ───────────────────
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── 네이버 데이터랩 API (검색어 추세, 상대값) ─────────────────────
NAVER_DATALAB_CLIENT_ID=
NAVER_DATALAB_CLIENT_SECRET=

# ── 기프트클린 연락처 기본값 (선택 — 문의 유도 문구에 참고용으로 사용) ──
GIFTCLEAN_KAKAO_CHANNEL=
GIFTCLEAN_PHONE=
GIFTCLEAN_HOMEPAGE=

# ── 업로드/실행 제한 (기본값 유지 권장) ───────────────────────────
MAX_IMAGE_SIZE_MB=20
MAX_IMAGES_PER_POST=60
MIN_SESSION_SECONDS=180
PORT=8787
